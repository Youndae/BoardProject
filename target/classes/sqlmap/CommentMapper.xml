	<select id="bCommentList" resultType="CommentVO">
		SELECT * FROM BoardComment WHERE BoardNo=#{BoardNo}
	</select>
	
	<select id="iCommentList" resultType="CommentVO">
	
	</select>
	
	<insert id="commentInsert" parameterType="CommentVO">
		INSERT INTO BoardComment(
						CommentNo
						, UserId
						, CommentContent
						, CommentDate
						, CommentGroupNo
						, CommentUpperNo
						, CommentIndent
						, ImageNo
						, BoardNo)
					VALUES(
						Comment_SEQ.NEXTVAL
						, #{UserId}
						, #{CommentContent}
						, sysdate
						, Comment_SEQ.NEXTVAL
						, 0
						, 0
						, #{ImageNo}
						, #{BoardNo}
					)
	</insert>
	
	<delete id="commentDelete" parameterType="int">
	 	DELETE FROM BoardComment WHERE CommentNo=#{CommentNo}
	</delete>
	
